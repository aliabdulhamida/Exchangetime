# Required: Financial Modeling Prep API Key (primary provider)
# Get it from: https://financialmodelingprep.com/
# Used for: DCF valuations, Free Cash Flow data, core stock metrics/market cap
FMP_API_KEY=your_fmp_api_key_here

# Optional fallback provider #1 (used when FMP is unavailable)
# Get it from: https://twelvedata.com/
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# Optional fallback provider #2 (used when FMP and Twelve Data are unavailable)
# Get it from: https://massive.com/ or https://polygon.io/
MASSIVE_API_KEY=your_massive_api_key_here

# Optional: RapidAPI key for Fear & Greed Index proxy endpoint (/api/fear-greed)
# Get it from: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here
