# Financial Modeling Prep API Key
# Get it from: https://financialmodelingprep.com/
# Used for: DCF valuations, Free Cash Flow data
FMP_API_KEY=your_fmp_api_key_here

# Twelve Data API Key (fallback provider when FMP is unavailable)
# Get it from: https://twelvedata.com/
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# Massive.com (Polygon.io) API Key (third fallback provider)
# Get it from: https://massive.com/ or https://polygon.io/
MASSIVE_API_KEY=your_massive_api_key_here
